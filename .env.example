# ─── API ──────────────────────────────────────────────────────────────────────
# For a single backend that handles both networks (controlled by STELLAR_NETWORK
# on the backend), set just this one:
NEXT_PUBLIC_API_URL=http://localhost:3004

# To run separate testnet and mainnet backends, set both:
# NEXT_PUBLIC_API_URL_TESTNET=https://api-testnet.yourdomain.com
# NEXT_PUBLIC_API_URL_MAINNET=https://api.yourdomain.com

# ─── Stellar Network ──────────────────────────────────────────────────────────
# Controls the default network on first load. Users can switch via the UI.
# The backend STELLAR_NETWORK must match for transactions to work.
NEXT_PUBLIC_STELLAR_NETWORK=testnet
# NEXT_PUBLIC_STELLAR_NETWORK=mainnet

# ─── Contract IDs ─────────────────────────────────────────────────────────────
# Testnet contracts (fill after ./scripts/deploy.sh on testnet):
NEXT_PUBLIC_ROUTE_AGGREGATOR_ID=
NEXT_PUBLIC_YIELD_VAULT_ID=
NEXT_PUBLIC_FEE_DISTRIBUTOR_ID=
NEXT_PUBLIC_PRICE_ORACLE_ID=

# Mainnet contracts (fill after mainnet deployment):
# NEXT_PUBLIC_ROUTE_AGGREGATOR_ID=C...
# NEXT_PUBLIC_YIELD_VAULT_ID=C...
# NEXT_PUBLIC_FEE_DISTRIBUTOR_ID=C...
# NEXT_PUBLIC_PRICE_ORACLE_ID=C...
